[app]
title = X-O Supreme
package.name = xosupreme.game
package.domain = org.krollos
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
version = 1.0
requirements = python3,kivy,plyer,requests,urllib3
orientation = portrait
